{
  "name": "penaltyiq",
  "version": "2.0.0",
  "private": true,
  "description": "AI-powered biomechanical analysis of football penalty kicks",
  "scripts": {
    "dev:web": "cd web && npm run dev",
    "dev:backend": "cd backend && python -m uvicorn backend.bridge:app --reload --host 127.0.0.1 --port 8000",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:backend\"",
    "test:backend": "cd backend && pytest tests/",
    "db:migrate": "cd web && npx prisma migrate dev",
    "db:seed": "cd web && npx prisma db seed",
    "db:studio": "cd web && npx prisma studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
